];

const reviews = {
  1:[
    {user:'أم محمود',rating:5,text:'محل رائع والأسعار منطقية جداً'},
    {user:'أحمد النعيمي',rating:5,text:'خدمة ممتازة والموظفين بشوش'},
  ],
  4:[
    {user:'علي',rating:5,text:'أفضل مطعم في سميسمة الطعم لا يضاهى'},
    {user:'فاطمة',rating:5,text:'النظافة والجودة على أعلى مستوى'},
  ],
  6:[
    {user:'محمد الدوسري',rating:5,text:'أفضل أسعار في أم قرن'},
    {user:'حنان',rating:4,text:'جيد لكن الزحام كتير بالأوقات الذروة'},
  ],
  13:[
    {user:'سالم',rating:5,text:'الأسماك طازة جداً والطاهي ماهر'},
    {user:'ليلى',rating:5,text:'تجربة رائعة وأسعار معقولة'},
    {user:'جاسم',rating:5,text:'أفضل مطعم بحري في الخور'},
  ],
};

let sortMode = 'rating';
let currentArea = 'all';

function renderStores(list) {
  const sorted = list.sort((a,b) => {
    if(sortMode==='rating') return b.rating-a.rating;
    if(sortMode==='distance') return Math.random()-0.5;
    return Math.random()-0.5;
  });

  document.getElementById('storeList').innerHTML = sorted.map(s => `
    <div class="store-card fade-in" onclick="openDetail(${s.id})">
      <div class="store-img">${s.icon}</div>
      <div class="store-info">
        <div class="store-name">${s.name}</div>
        <div class="store-sub">${s.type} · ${s.area}</div>
        <div class="store-meta">
          <span class="badge open">📍 ${s.area}</span>
          <span class="star-badge">
            <span class="stars">⭐⭐⭐⭐⭐</span>
            <span class="score">${s.rating}</span>
          </span>
        </div>
      </div>
      <div class="store-arrow">›</div>
    </div>`).join('');
}

function setSortHome(el, mode) {
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  sortMode = mode;
  renderStores(stores.filter(s => currentArea==='all'?true:s.areaCode===currentArea));
}

function filterArea(el, area) {
  document.querySelectorAll('#home .cat').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  currentArea = area;
  renderStores(area==='all' ? stores : stores.filter(s=>s.areaCode===area));
}

function handleSearch(v) {
  if(!v){renderStores(stores);return;}
  renderStores(stores.filter(s=>s.name.includes(v)||s.type.includes(v)||s.area.includes(v)));
}

function openDetail(id) {
  const s = stores.find(x=>x.id===id);
  document.getElementById('detIcon').textContent = s.icon;
  document.getElementById('detName').textContent = s.name;
  document.getElementById('detCat').textContent  = s.type;
  document.getElementById('detArea').textContent = `📍 ${s.area}`;
  document.getElementById('detPhone').textContent = s.phone;
  document.getElementById('detWork').textContent = s.workHours;
  document.getElementById('detType').textContent = s.type;
  document.getElementById('detRating').textContent = '⭐ '+s.rating;

  const st = document.getElementById('detStatus');
  st.textContent = '🟢 مفتوح الآن';
  st.className = 'badge open';

  document.getElementById('detRatingScore').textContent = s.rating;
  const stars = '⭐'.repeat(Math.round(s.rating)) + '☆'.repeat(5-Math.round(s.rating));
  document.getElementById('detRatingStars').textContent = stars;
  document.getElementById('detRatingCount').textContent = `من ${s.reviews} تقييم`;

  const dist = s.ratingDist;
  const total = Object.values(dist).reduce((a,b)=>a+b,0);
  document.getElementById('ratingBars').innerHTML = [5,4,3,2,1].map(num => {
    const pct = (dist[num]/total)*100;
    return `<div class="rating-bar">
      <div class="rating-bar-num">${num}⭐</div>
      <div class="rating-bar-track"><div class="rating-bar-fill" style="width:${pct}%"></div></div>
      <div class="rating-bar-count">${dist[num]}</div>
    </div>`;
  }).join('');

  const storeReviews = reviews[id] || [];
  document.getElementById('reviewsList').innerHTML = storeReviews.map(r => `
    <div class="review-item">
      <div class="review-user">
        <div class="review-name">👤 ${r.user}</div>
        <div class="review-date">قبل أسبوع</div>
      </div>
      <div class="review-rating">${'⭐'.repeat(r.rating)}</div>
      <div class="review-text">"${r.text}"</div>
    </div>`).join('') || '<div style="color:var(--text-muted);text-align:center;padding:20px">لا توجد تقييمات بعد</div>';

  goTo('detail');
}

function callStore() {
  const phone = document.getElementById('detPhone').textContent;
  alert(`جاري الاتصال بـ ${phone}\n\nملاحظة: في التطبيق الحقيقي سيتم فتح تطبيق الهاتف`);
}

function addReview() {
  alert('شكراً! في التطبيق الحقيقي يمكنك إضافة تقييمك هنا');
}

function goTo(screen) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(screen).classList.add('active');
  window.scrollTo(0,0);
}

renderStores(stores);
</script>
